# When running with Docker Compose, use "db" as host (the postgres service name)
DATABASE_URL=postgresql+asyncpg://radar:radar_dev@db:5432/ai_radar
# When running locally (outside Docker): DATABASE_URL=postgresql+asyncpg://radar:radar_dev@localhost:5432/ai_radar

# AI — Vertex AI (dùng Application Default Credentials)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
# Nếu dùng Service Account JSON: đặt path tới file key
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa-key.json

# Backend
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Admin API
ADMIN_API_KEY=changeme

# Environment
ENV=development
